# Copiez vers un fichier ignoré par Git (ex. à la racine du site : .env.local)
# ou exportez ces variables dans le shell avant : node supabase/scripts/import-medlex-templates.mjs
#
# Ne commitez jamais de vraies clés.

SUPABASE_URL=https://VOTRE_PROJECT_REF.supabase.co
# Clé secrète (service role / Secret API key) — backend / scripts uniquement
SUPABASE_SECRET_KEY=
# Alias acceptés par le script : SUPABASE_SERVICE_ROLE_KEY, SUPABASE_SECRET_SERVICE_ROLE_KEY
